            local function setState(on)
                state = on
                if on then
                    TweenService:Create(Pill, ti,{BackgroundColor3=C.accentD}):Play()
                    TweenService:Create(Thumb,ti,{Position=UDim2.new(0,23,0.5,-9),BackgroundColor3=C.accent}):Play()
                    cs.Color = C.accentD
                    badge.Text = "ON"; badge.TextColor3 = C.accent
                    badge.BackgroundColor3 = Color3.fromRGB(0,30,55)
                else
                    TweenService:Create(Pill, ti,{BackgroundColor3=C.border}):Play()
                    TweenService:Create(Thumb,ti,{Position=UDim2.new(0,3,0.5,-9),BackgroundColor3=C.sub}):Play()
                    cs.Color = C.border
                    badge.Text = "OFF"; badge.TextColor3 = C.sub
                    badge.BackgroundColor3 = C.panel
                end
                if cb then cb(on) end
            end

            -- init visual
            if state then
                Pill.BackgroundColor3 = C.accentD; cs.Color = C.accentD
                Thumb.Position = UDim2.new(0,23,0.5,-9); Thumb.BackgroundColor3 = C.accent
                badge.Text = "ON"; badge.TextColor3 = C.accent
