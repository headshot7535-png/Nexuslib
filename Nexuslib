            iL.Text = icon; iL.Size = UDim2.new(0,36,1,0); iL.Position = UDim2.new(0,6,0,0)
            iL.BackgroundTransparency = 1; iL.TextSize = 18; iL.Font = Enum.Font.GothamBold
            iL.TextXAlignment = Enum.TextXAlignment.Center

            local nL = Instance.new("TextLabel",Card)
            nL.Text = label; nL.Size = UDim2.new(1,-50,0,18); nL.Position = UDim2.new(0,46,0,6)
            nL.BackgroundTransparency = 1; nL.TextColor3 = accentCol
            nL.Font = Enum.Font.GothamBold; nL.TextSize = 11; nL.TextXAlignment = Enum.TextXAlignment.Left

            local dL = Instance.new("TextLabel",Card)
            dL.Text = desc or ""; dL.Size = UDim2.new(1,-50,0,13); dL.Position = UDim2.new(0,46,0,24)
            dL.BackgroundTransparency = 1; dL.TextColor3 = C.sub
            dL.Font = Enum.Font.Gotham; dL.TextSize = 9; dL.TextXAlignment = Enum.TextXAlignment.Left

            Card.MouseButton1Click:Connect(function()
                TweenService:Create(Card,TweenInfo.new(0.08),{BackgroundColor3=Color3.fromRGB(20,25,40)}):Play()
                task.delay(0.15,function() TweenService:Create(Card,TweenInfo.new(0.15),{BackgroundColor3=C.card}):Play() end)
                if cb then cb() end
            end)
            return Card
        end

        -- ── Label ─────────────────────────────────────────
        function T:Label(txt)
            order = order + 1
            local f = Instance.new("Frame", page)
            f.Size = UDim2.new(1,-10,0,28); f.BackgroundTransparency = 1; f.LayoutOrder = order
            local l = Instance.new("TextLabel", f)
            l.Size = UDim2.new(1,0,1,0); l.BackgroundTransparency = 1
            l.TextColor3 = C.sub; l.Font = Enum.Font.Gotham; l.TextSize = 10
            l.TextXAlignment = Enum.TextXAlignment.Left; l.TextWrapped = true
            l.Text = txt
            return { Set = function(s) l.Text = s end }
        end

        return T
    end

    -- ============================================================
    --  BUILT-IN: Chat Tab (Firebase cross-server)
    -- ============================================================
    function Win:ChatTab(firebaseUrl)
        firebaseUrl = firebaseUrl or "https://anipixels-chat-default-rtdb.firebaseio.com/chat"
        local T = self:Tab("💬","Chat")

        -- info bar
        local InfoCard = Instance.new("Frame", T._page)
        InfoCard.Size = UDim2.new(1,-10,0,28); InfoCard.BackgroundColor3 = Color3.fromRGB(30,30,45)
        InfoCard.BorderSizePixel = 0; InfoCard.LayoutOrder = 1
        Instance.new("UICorner",InfoCard).CornerRadius = UDim.new(0,8)
        local InfoLbl = Instance.new("TextLabel",InfoCard)
        InfoLbl.Size = UDim2.new(1,-10,1,0); InfoLbl.Position = UDim2.new(0,8,0,0)
        InfoLbl.BackgroundTransparency = 1; InfoLbl.TextColor3 = C.sub
        InfoLbl.Font = Enum.Font.Gotham; InfoLbl.TextSize = 9; InfoLbl.TextWrapped = true
        InfoLbl.TextXAlignment = Enum.TextXAlignment.Left
        InfoLbl.Text = "💬 Cross-server chat"

        -- feed
        local FeedOuter = Instance.new("Frame", T._page)
        FeedOuter.Size = UDim2.new(1,-10,0,200); FeedOuter.BackgroundColor3 = Color3.fromRGB(14,14,22)
        FeedOuter.BorderSizePixel = 0; FeedOuter.LayoutOrder = 2; FeedOuter.ClipsDescendants = true
        Instance.new("UICorner",FeedOuter).CornerRadius = UDim.new(0,10)
        Instance.new("UIStroke",FeedOuter).Color = C.border

        local FeedScroll = Instance.new("ScrollingFrame",FeedOuter)
        FeedScroll.Size = UDim2.new(1,0,1,0); FeedScroll.BackgroundTransparency = 1
        FeedScroll.BorderSizePixel = 0; FeedScroll.ScrollBarThickness = 3
        FeedScroll.ScrollBarImageColor3 = C.accent; FeedScroll.CanvasSize = UDim2.new(0,0,0,0)
        FeedScroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
        local FeedLayout = Instance.new("UIListLayout",FeedScroll)
        FeedLayout.SortOrder = Enum.SortOrder.LayoutOrder; FeedLayout.Padding = UDim.new(0,2)
        local FeedPad = Instance.new("UIPadding",FeedScroll)
        FeedPad.PaddingLeft = UDim.new(0,6); FeedPad.PaddingRight = UDim.new(0,6)

        local function addLine(user, text, server, isSystem)
            local row = Instance.new("Frame",FeedScroll)
            row.Size = UDim2.new(1,0,0,0); row.AutomaticSize = Enum.AutomaticSize.Y
            row.BackgroundTransparency = 1; row.LayoutOrder = #FeedScroll:GetChildren()
            local lbl = Instance.new("TextLabel",row)
            lbl.Size = UDim2.new(1,0,0,0); lbl.AutomaticSize = Enum.AutomaticSize.Y
            lbl.BackgroundTransparency = 1; lbl.TextWrapped = true
            lbl.TextXAlignment = Enum.TextXAlignment.Left
            lbl.Font = Enum.Font.Code; lbl.TextSize = 10
            if isSystem then
                lbl.TextColor3 = C.sub; lbl.Text = "— "..text
            else
                lbl.TextColor3 = C.text
                lbl.Text = "["..tostring(server or "?").."] "..tostring(user or "Anon")..": "..tostring(text)
            end
            task.defer(function()
                FeedScroll.CanvasPosition = Vector2.new(0, FeedLayout.AbsoluteContentSize.Y)
            end)
        end

        -- input
        local InputCard = Instance.new("Frame",T._page)
        InputCard.Size = UDim2.new(1,-10,0,36); InputCard.BackgroundColor3 = C.card
        InputCard.BorderSizePixel = 0; InputCard.LayoutOrder = 3
        Instance.new("UICorner",InputCard).CornerRadius = UDim.new(0,10)
        Instance.new("UIStroke",InputCard).Color = C.border

        local ChatInput = Instance.new("TextBox",InputCard)
        ChatInput.Size = UDim2.new(1,-56,1,-8); ChatInput.Position = UDim2.new(0,8,0,4)
        ChatInput.BackgroundColor3 = Color3.fromRGB(18,18,26); ChatInput.BorderSizePixel = 0
        ChatInput.TextColor3 = C.text; ChatInput.Font = Enum.Font.Gotham; ChatInput.TextSize = 10
        ChatInput.PlaceholderText = "Type a message..."; ChatInput.Text = ""
        ChatInput.ClearTextOnFocus = false; ChatInput.ClipsDescendants = true
        Instance.new("UICorner",ChatInput).CornerRadius = UDim.new(0,6)
        Instance.new("UIPadding",ChatInput).PaddingLeft = UDim.new(0,6)

        local SendBtn = Instance.new("TextButton",InputCard)
        SendBtn.Size = UDim2.new(0,44,1,-8); SendBtn.Position = UDim2.new(1,-50,0,4)
        SendBtn.BackgroundColor3 = C.accent; SendBtn.BorderSizePixel = 0
        SendBtn.TextColor3 = Color3.fromRGB(255,255,255); SendBtn.Font = Enum.Font.GothamBold
        SendBtn.TextSize = 10; SendBtn.Text = "Send"
        Instance.new("UICorner",SendBtn).CornerRadius = UDim.new(0,6)

        local OnlineCard = Instance.new("Frame",T._page)
        OnlineCard.Size = UDim2.new(1,-10,0,20); OnlineCard.BackgroundTransparency = 1
        OnlineCard.LayoutOrder = 4
        local OnlineLbl = Instance.new("TextLabel",OnlineCard)
        OnlineLbl.Size = UDim2.new(1,0,1,0); OnlineLbl.BackgroundTransparency = 1
        OnlineLbl.TextColor3 = C.sub; OnlineLbl.Font = Enum.Font.Gotham; OnlineLbl.TextSize = 9
        OnlineLbl.TextXAlignment = Enum.TextXAlignment.Left
        OnlineLbl.Text = "🟡 Connecting..."

        local function shortSrv()
            local j = game.JobId
            return j ~= "" and j:sub(1,5) or "local"
        end

        local function doSend(text)
            if text == "" then return end
            local payload = HS:JSONEncode({
                user   = "Anonymous",
                server = shortSrv(),
                text   = text,
                time   = os.time(),
            })
            local ok, res = pcall(httpRequest, {
                Url     = firebaseUrl..".json",
                Method  = "POST",
                Headers = { ["Content-Type"] = "application/json" },
                Body    = payload,
            })
            if not ok or not res then
                addLine(nil, "❌ Send failed: "..tostring(res), nil, true)
            elseif res.StatusCode and res.StatusCode >= 400 then
                addLine(nil, "❌ HTTP "..res.StatusCode, nil, true)
            end
        end

        SendBtn.MouseButton1Click:Connect(function()
            local txt = ChatInput.Text:match("^%s*(.-)%s*$")
            if txt == "" then return end
            doSend(txt); ChatInput.Text = ""
        end)
        ChatInput.FocusLost:Connect(function(enter)
            if enter then
                local txt = ChatInput.Text:match("^%s*(.-)%s*$")
                if txt ~= "" then doSend(txt); ChatInput.Text = "" end
            end
        end)

        -- poll
        task.spawn(function()
            _G.NexusLib_ChatGen = (_G.NexusLib_ChatGen or 0) + 1
            local myGen = _G.NexusLib_ChatGen
            local seen = {}

            local function fetch()
                local ok, res = pcall(httpRequest, {
                    Url     = firebaseUrl..".json",
                    Method  = "GET",
                    Headers = { ["Accept"] = "application/json" },
                })
                if not ok or not res or not res.Body or res.Body == "" or res.Body == "null" then return false end
                local ok2, data = pcall(HS.JSONDecode, HS, res.Body)
                if not ok2 or type(data) ~= "table" then return false end
                local msgs = {}
                for key, v in pairs(data) do
                    if type(v) == "table" and v.time and not seen[key] then
                        table.insert(msgs, {key=key,user=v.user,server=v.server,text=v.text,time=v.time})
                    end
                end
                table.sort(msgs, function(a,b) return a.time < b.time end)
                local start = math.max(1, #msgs - 29)
                for i = start, #msgs do
                    seen[msgs[i].key] = true
                    addLine(msgs[i].user, msgs[i].text, msgs[i].server, false)
                end
                return #msgs > 0
            end

            fetch()
            OnlineLbl.Text = "🟢 Live"

            while true do
                if _G.NexusLib_ChatGen ~= myGen then break end
                task.wait(3)
                if _G.NexusLib_ChatGen ~= myGen then break end
                fetch()
            end
        end)
    end

    -- ============================================================
    --  BUILT-IN: Player Tab (jump, speed, anti afk)
    -- ============================================================
    function Win:PlayerTab()
        local T = self:Tab("👤","Player")
        local runGen = newGen()

        T:Section("Movement")

        -- Walk Speed
        local speedRef = { val = 16 }
        T:Slider("Walk Speed","Default 16 · Max 300",{min=0,max=300,default=16}, function(v)
            speedRef.val = v
            local h = getHuman()
            if h then h.WalkSpeed = v end
        end)

        -- Inf Jump
        T:Toggle("🚀 Infinite Jump","Jump again while airborne", false, function(on)
            local myGen = newGen(); runGen = myGen
            if on then
                local conn; conn = UserInputService.JumpRequest:Connect(function()
                    if runGen ~= myGen then conn:Disconnect(); return end
                    local h = getHuman()
                    if h then h:ChangeState(Enum.HumanoidStateType.Jumping) end
                end)
            end
        end)

        -- Walk speed reapply on respawn
        Players.LocalPlayer.CharacterAdded:Connect(function(char)
            local h = char:WaitForChild("Humanoid", 5)
            if h then h.WalkSpeed = speedRef.val end
        end)

        T:Section("Utility")

        -- Anti AFK
        T:Toggle("⏱️ Anti AFK","Prevents auto-kick every 55s", false, function(on)
            local myGen = newGen(); runGen = myGen
            if on then
                task.spawn(function()
                    local VU = game:GetService("VirtualUser")
                    while true do
                        if runGen ~= myGen then break end
                        task.wait(55)
                        if runGen ~= myGen then break end
                        VU:Button2Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
                        task.wait(0.1)
                        VU:Button2Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
                    end
                end)
            end
        end)

        -- Noclip
        T:Toggle("👻 No Clip","Walk through walls", false, function(on)
            local myGen = newGen(); runGen = myGen
            if on then
                local conn; conn = RunService.Stepped:Connect(function()
                    if runGen ~= myGen then conn:Disconnect(); return end
                    local c = getChar()
                    if c then
                        for _, p in pairs(c:GetDescendants()) do
                            if p:IsA("BasePart") then p.CanCollide = false end
                        end
                    end
                end)
            end
        end)

        -- God Mode
        T:Toggle("🛡️ God Mode","Lock health to max", false, function(on)
            local myGen = newGen(); runGen = myGen
            if on then
                task.spawn(function()
                    while true do
                        if runGen ~= myGen then break end
                        local h = getHuman()
                        if h then h.Health = h.MaxHealth end
                        task.wait(0.1)
                    end
                end)
            end
        end)

        T:Section("Actions")

        T:Button("🔄","Respawn","Reset character", C.purple, function()
            local h = getHuman()
            if h then h.Health = 0 end
        end)

        T:Button("📋","Print Position","Prints XYZ to output", C.accent, function()
            local r = getRoot()
            if r then
                local p = r.Position
                print(string.format("[NexusLib] Position: X=%.1f Y=%.1f Z=%.1f", p.X, p.Y, p.Z))
            end
        end)

        return T
    end

    -- first tab auto-shown when Win:Tab is first called, so just return Win
    return Win
end

return NexusLib
