    -- ── Window object ────────────────────────────────────────
    local PRESENCE_URL = "https://anipixels-chat-default-rtdb.firebaseio.com/presence"
    -- Fixed key per player = re-executing overwrites same slot, never duplicates
    local MY_KEY = tostring(LP.UserId)

