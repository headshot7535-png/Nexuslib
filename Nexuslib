    function Win:Status(msg) SLbl.Text = msg end

    -- ── Live user count (right side of status bar) ────────────
    local function startPresence()
        _G.NexusLib_PresenceGen = (_G.NexusLib_PresenceGen or 0) + 1
        local myGen = _G.NexusLib_PresenceGen
        local serverID = game.JobId ~= "" and game.JobId:sub(1,8) or "studio"

        local function upsert()
            pcall(httpRequest, {
                Url     = PRESENCE_URL.."/"..MY_KEY..".json",
                Method  = "PUT",
                Headers = { ["Content-Type"] = "application/json" },
                Body    = '{"t":' .. os.time() .. ',"s":"' .. serverID .. '"}',
            })
        end

        local function countOnline()
            local ok, res = pcall(httpRequest, {
                Url     = PRESENCE_URL..".json",
                Method  = "GET",
                Headers = { ["Accept"] = "application/json" },
            })
            if not ok or not res or not res.Body or res.Body == "null" or res.Body == "" then
                return 1
            end
            local ok2, data = pcall(HS.JSONDecode, HS, res.Body)
            if not ok2 or type(data) ~= "table" then return 1 end
            local now = os.time()
            local count = 0
            for _, v in pairs(data) do
                if type(v) == "table" and v.t and (now - v.t) <= 45 then
                    count = count + 1
                end
            end
            return math.max(1, count)
        end

        task.spawn(function()
            upsert()
            local count = countOnline()
            OnlineCountLbl.Text = "🟢 "..count.." online"

            while true do
                if _G.NexusLib_PresenceGen ~= myGen then
                    -- zero out our timestamp so we drop out of TTL instantly
                    pcall(httpRequest, {
                        Url     = PRESENCE_URL.."/"..MY_KEY..".json",
                        Method  = "PUT",
                        Headers = { ["Content-Type"] = "application/json" },
                        Body    = '{"t":0,"s":"gone"}',
                    })
                    break
                end
                task.wait(20)
                upsert()
                count = countOnline()
                OnlineCountLbl.Text = "🟢 "..count.." online"
            end
        end)
    end

    startPresence()

