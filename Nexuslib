        -- ── Slider ────────────────────────────────────────
        function T:Slider(label, desc, opts, cb)
            order = order + 1
            local minV    = opts.min     or 0
            local maxV    = opts.max     or 100
            local initV   = opts.default or minV
            local fmt     = opts.format  or function(v) return tostring(math.floor(v)) end

            local Card = Instance.new("Frame", page)
            Card.Size = UDim2.new(1,-10,0,60); Card.BackgroundColor3 = C.card
            Card.BorderSizePixel = 0; Card.LayoutOrder = order
            Instance.new("UICorner",Card).CornerRadius = UDim.new(0,10)
            Instance.new("UIStroke",Card).Color = C.border

            local nL = Instance.new("TextLabel",Card)
            nL.Text = label; nL.Size = UDim2.new(1,-80,0,18); nL.Position = UDim2.new(0,14,0,6)
            nL.BackgroundTransparency = 1; nL.TextColor3 = C.text
            nL.Font = Enum.Font.GothamBold; nL.TextSize = 12; nL.TextXAlignment = Enum.TextXAlignment.Left

            local vL = Instance.new("TextLabel",Card)
            vL.Text = fmt(initV); vL.Size = UDim2.new(0,60,0,18); vL.Position = UDim2.new(1,-68,0,6)
            vL.BackgroundTransparency = 1; vL.TextColor3 = C.accent
            vL.Font = Enum.Font.Code; vL.TextSize = 13; vL.TextXAlignment = Enum.TextXAlignment.Right

            local dL = Instance.new("TextLabel",Card)
            dL.Text = desc or ""; dL.Size = UDim2.new(1,-80,0,12); dL.Position = UDim2.new(0,14,0,26)
            dL.BackgroundTransparency = 1; dL.TextColor3 = C.sub
            dL.Font = Enum.Font.Gotham; dL.TextSize = 9; dL.TextXAlignment = Enum.TextXAlignment.Left

            local Track = Instance.new("Frame",Card)
            Track.Size = UDim2.new(1,-28,0,6); Track.Position = UDim2.new(0,14,0,44)
            Track.BackgroundColor3 = C.panel; Track.BorderSizePixel = 0
            Instance.new("UICorner",Track).CornerRadius = UDim.new(1,0)

            local pct0 = (initV-minV)/(maxV-minV)
            local Fill = Instance.new("Frame",Track)
            Fill.Size = UDim2.new(pct0,0,1,0); Fill.BackgroundColor3 = C.accent; Fill.BorderSizePixel = 0
            Instance.new("UICorner",Fill).CornerRadius = UDim.new(1,0)

            local Knob = Instance.new("TextButton",Track)
            Knob.Text = ""; Knob.Size = UDim2.new(0,16,0,16); Knob.AnchorPoint = Vector2.new(0.5,0.5)
            Knob.Position = UDim2.new(pct0,0,0.5,0)
            Knob.BackgroundColor3 = Color3.fromRGB(255,255,255); Knob.BorderSizePixel = 0; Knob.ZIndex = 4
            Instance.new("UICorner",Knob).CornerRadius = UDim.new(1,0)

            local curVal = initV
            local dragging = false
            local function apply(ix)
                local rel = math.clamp(ix - Track.AbsolutePosition.X, 0, Track.AbsoluteSize.X)
                local p   = rel / Track.AbsoluteSize.X
                local v   = minV + math.round((maxV-minV)*p)
                curVal = v
                Fill.Size = UDim2.new(p,0,1,0); Knob.Position = UDim2.new(p,0,0.5,0)
                vL.Text = fmt(v)
                if cb then cb(v) end
            end
            Knob.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true end
            end)
            UserInputService.InputChanged:Connect(function(i)
                if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then apply(i.Position.X) end
            end)
            UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
            end)
            Track.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then apply(i.Position.X) end
            end)

            return { Get = function() return curVal end }
        end

